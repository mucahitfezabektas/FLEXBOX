{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FLEXBOX",
  "version": "0.1.0",
  "identifier": "com.flexbox.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FLEXBOX",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 680,
        "devtools": true,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "externalBin": [
      "binaries/flexbox-backend"
    ],
    "icon": [
      "icons/app.ico"
    ]
  }
}
